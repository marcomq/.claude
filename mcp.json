"mcpServers": {
    "github.com/upstash/context7-mcp": {
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "autoApprove": [],
      "command": "npx",
      "disabled": false,
      "env": {}
    },
    "rust_analyzer": {
      "args": [],
